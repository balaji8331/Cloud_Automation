# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — copy this file to .env and fill in real values
# PRODUCTION    — add all keys marked [SECRET] to GitHub → Settings → Secrets
# ─────────────────────────────────────────────────────────────────────────────

# Database                                                  [SECRET] → DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/azure_cost_portal"

# NextAuth                                                  [SECRET] → NEXTAUTH_URL, NEXTAUTH_SECRET
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# AES-256 key for encrypting Azure client secrets           [SECRET] → SECRET_ENCRYPTION_KEY
# Generate: openssl rand -hex 32
SECRET_ENCRYPTION_KEY="64-hex-chars-here"

# Email via Resend (https://resend.com)                     [SECRET] → RESEND_API_KEY
RESEND_API_KEY="re_..."
ALERT_FROM_EMAIL="alerts@yourdomain.com"
ALERT_TO_EMAIL="admin@yourdomain.com"                       # [SECRET] → ALERT_TO_EMAIL

# Anomaly detection default threshold (%)                   [SECRET] → DEFAULT_ANOMALY_THRESHOLD
DEFAULT_ANOMALY_THRESHOLD=50

# Exchange rates: 1 USD = X units                          [SECRET] → EXCHANGE_RATES_TO_USD
# Update monthly. Format: CURRENCY_CODE:rate,...
EXCHANGE_RATES_TO_USD=INR:83.5,EUR:0.92,GBP:0.79,AUD:1.53,CAD:1.36,JPY:157.0,SGD:1.34,AED:3.67,CHF:0.89

# ─── Terminal / Super Admin CLI (optional) ────────────────────────────────────
# Port for the WebSocket sidecar server
TERMINAL_WS_PORT=3001
# Browser WS URL (Next.js frontend connects here)
NEXT_PUBLIC_TERMINAL_WS_URL=ws://localhost:3001
# Idle timeout in ms (15 min default)
TERMINAL_IDLE_TIMEOUT_MS=900000
# Max session duration in ms (2 hours default)
TERMINAL_MAX_SESSION_MS=7200000
# Azure CLI Docker image
TERMINAL_DOCKER_IMAGE=mcr.microsoft.com/azure-cli
# Terminal backend: use aci for Azure Container Instances, or local_unsafe_dev_only for local shell access
TERMINAL_ADAPTER=aci

# Azure Container Instances terminal backend (optional)
ACI_SUBSCRIPTION_ID=
ACI_RESOURCE_GROUP=ScriptRunner
ACI_LOCATION=eastus
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
