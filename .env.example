# Anomaly detection default threshold (percentage, e.g. 50 = 50% spike)
DEFAULT_ANOMALY_THRESHOLD=50

# Exchange rates relative to USD (1 USD = X units of currency)
# Update monthly. Format: CURRENCY_CODE:rate,CURRENCY_CODE:rate
# Example: 1 USD = 83.5 INR, 1 USD = 0.92 EUR
EXCHANGE_RATES_TO_USD=INR:83.5,EUR:0.92,GBP:0.79,AUD:1.53,CAD:1.36,JPY:157.0,SGD:1.34,AED:3.67,CHF:0.89

# Optional: Azure Key Vault URI (swap SECRET_ENCRYPTION_KEY for Key Vault later)
# AZURE_KEY_VAULT_URI="https://your-vault.vault.azure.net"

# Terminal Server (Super Admin CLI feature)
# Port for the WebSocket sidecar server (default: 3001)
TERMINAL_WS_PORT=3001
# Browser-side WS URL (used by Next.js frontend to connect to the terminal server)
NEXT_PUBLIC_TERMINAL_WS_URL=ws://localhost:3001
# Idle timeout in milliseconds (default: 15 min = 900000)
TERMINAL_IDLE_TIMEOUT_MS=900000
# Max session duration in milliseconds (default: 2 hours = 7200000)
TERMINAL_MAX_SESSION_MS=7200000
# Azure CLI Docker image (default: mcr.microsoft.com/azure-cli)
TERMINAL_DOCKER_IMAGE=mcr.microsoft.com/azure-cli
