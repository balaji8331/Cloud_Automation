# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT - copy this file to .env and fill in real values
# PRODUCTION - add [GITHUB SECRET] values to GitHub Settings -> Secrets and
#              [GITHUB VARIABLE] values to GitHub Settings -> Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Database
# Docker Compose overrides this to use the db container in production.
DATABASE_URL="postgresql://user:password@localhost:5432/azure_cost_portal"

# NextAuth                                                  [GITHUB SECRET]
NEXTAUTH_URL="https://portal.balaji.page"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# AES-256 key for encrypting Azure client secrets           [GITHUB SECRET]
# Generate: openssl rand -hex 32
SECRET_ENCRYPTION_KEY="64-hex-chars-here"

# Email via Resend (https://resend.com)                     [GITHUB SECRET]
RESEND_API_KEY="re_..."
ALERT_FROM_EMAIL="alerts@yourdomain.com"
ALERT_TO_EMAIL="admin@yourdomain.com"

# Anomaly detection default threshold (%)                   [GITHUB SECRET]
DEFAULT_ANOMALY_THRESHOLD=50

# Exchange rates: 1 USD = X units                          [GITHUB SECRET]
# Update monthly. Format: CURRENCY_CODE:rate,...
EXCHANGE_RATES_TO_USD=INR:83.5,EUR:0.92,GBP:0.79,AUD:1.53,CAD:1.36,JPY:157.0,SGD:1.34,AED:3.67,CHF:0.89

# Terminal / Super Admin CLI                                [GITHUB VARIABLE]
# Port for the WebSocket sidecar server.
TERMINAL_WS_PORT=3001
# Browser WS URL. Your reverse proxy must route WebSocket traffic to worker port 3001.
NEXT_PUBLIC_TERMINAL_WS_URL=wss://portal.balaji.page
# Idle timeout in ms (15 min default).
TERMINAL_IDLE_TIMEOUT_MS=900000
# Max session duration in ms (2 hours default).
TERMINAL_MAX_SESSION_MS=7200000
# Azure CLI Docker image.
TERMINAL_DOCKER_IMAGE=mcr.microsoft.com/azure-cli
# Terminal backend: use aci for Azure Container Instances, or local_unsafe_dev_only for local shell access.
TERMINAL_ADAPTER=aci

# Azure Container Instances terminal backend
# Secrets
ACI_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Variables
ACI_RESOURCE_GROUP=ScriptRunner
ACI_LOCATION=eastus
